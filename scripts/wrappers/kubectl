#!/bin/bash
# kubectl safety wrapper — bcgov/copilot-instructions
# Installed to ~/.local/bin/kubectl by scripts/setup.sh
# Blocks all kubectl commands for AI agents except tab completion.
#
# Uses PATH shadowing instead of `export -f` to avoid BASH_FUNC_*%% environment
# variable corruption when the user shell env is forwarded through agent runners
# that parse `env` output line-by-line.

# Locate the real kubectl binary, skipping this wrapper's own directory.
_real_bin() {
    local cmd="$1"
    local this_dir wrapper_path bin_dir="$HOME/.local/bin"
    # Resolve the directory this wrapper is running from, even when invoked via PATH.
    wrapper_path="$0"
    if [[ "$wrapper_path" != */* ]]; then
        wrapper_path="$(command -v -- "$wrapper_path" 2>/dev/null || true)"
    fi
    wrapper_path="${wrapper_path:-$0}"
    this_dir="$(cd "$(dirname "$wrapper_path")" && pwd -P)"
    while IFS= read -r dir; do
        dir="${dir:-.}" # empty PATH entries mean the current directory
        [[ "$dir" == "$this_dir" ]] && continue
        [[ "$dir" == "$bin_dir" ]] && continue
        [[ -x "$dir/$cmd" ]] && echo "$dir/$cmd" && return 0
    done < <(printf '%s' "$PATH" | tr ':' '\n')
    echo "ERROR: Real '$cmd' not found in PATH (excluding $this_dir and $bin_dir)" >&2
    exit 127
}

REAL_KUBECTL="$(_real_bin kubectl)" || exit $?

is_agent=false
if [[ -n "${ANTIGRAVITY_AGENT:-}" || -n "${AGENT_ID:-}" || -n "${KILO_AGENT:-}" || -n "${CURSOR_AGENT:-}" || -n "${GITHUB_COPILOT:-}" || -n "${AI_AGENT:-}" ]]; then
    is_agent=true
fi

if [[ "$is_agent" != "true" ]]; then
    exec "$REAL_KUBECTL" "$@"
fi

# Allow only cobra-style completion calls (__complete or __completeNoDesc).
# Both COMP_LINE and COMP_POINT must be set and the first argument must be
# the cobra completion sentinel for this to be treated as a completion call.
is_completion=false
if [[ -n "${COMP_LINE:-}" && -n "${COMP_POINT:-}" && ( "${1:-}" == "__complete" || "${1:-}" == "__completeNoDesc" ) ]]; then
    is_completion=true
fi

if [[ "$is_completion" != "true" ]]; then
    echo "BLOCKED: AI Agents are STRICTLY FORBIDDEN from running Kubernetes (kubectl) commands directly." >&2
    echo "         Direct cluster interaction is restricted to ensure system stability." >&2
    echo "         HALT immediately and request manual action from the USER." >&2
    exit 1
fi

exec "$REAL_KUBECTL" "$@"
